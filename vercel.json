{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/services/strategy", "destination": "/services/systems", "permanent": true },
    { "source": "/services/strategy/:path*", "destination": "/services/systems/:path*", "permanent": true },
    { "source": "/portfolio/strategy", "destination": "/portfolio/systems", "permanent": true },
    { "source": "/portfolio/strategy/:path*", "destination": "/portfolio/systems/:path*", "permanent": true }
  ],
  "rewrites": [
    { "source": "/g/bill",        "destination": "/sales-growth-engine/index.html?ref=bill-gerard" },
    { "source": "/partners/bill", "destination": "/sales-growth-engine/index.html?ref=bill-gerard" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    },
    {
      "source": "/(.*)",
      "missing": [
        {
          "type": "host",
          "value": "^(www\\.)?revelationagency\\.com$"
        }
      ],
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
